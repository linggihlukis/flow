{
  "flow_version": "1.0.0",
  "runtime": "opencode",
  "mode": "interactive",
  "depth": "standard",
  "model_profile": {
    "planning": "auto",
    "execution": "auto",
    "verification": "auto"
  },
  "workflow": {
    "research": true,
    "plan_check": true,
    "verifier": true,
    "node_repair": true,
    "node_repair_budget": 2,
    "parallel_execution": true,
    "commit_docs": true
  },
  "git": {
    "branching_strategy": "none",
    "phase_branch_template": "flow/phase-{phase}-{slug}",
    "milestone_branch_template": "flow/{milestone}-{slug}"
  },
  "destructive_tier": {
    "database": true,
    "env_files": true,
    "git_history": true
  }
}
